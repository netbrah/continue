{
  "name": "deepdive",
  "icon": "media/icon.png",
  "author": "netbrah",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/netbrah/continue"
  },
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "license": "Apache-2.0",
  "displayName": "DeepDive — Codebase Research Agent",
  "description": "A minimal codebase research agent sidebar",
  "publisher": "netbrah",
  "engines": {
    "vscode": "^1.70.0",
    "node": ">=20.19.0"
  },
  "engine-strict": true,
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:deepdive.chatView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "DeepDive",
      "properties": {
        "deepdive.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable DeepDive extension"
        }
      }
    },
    "commands": [
      {
        "command": "deepdive.newSession",
        "category": "DeepDive",
        "title": "New Session",
        "icon": "$(add)"
      }
    ],
    "keybindings": [
      {
        "command": "workbench.view.extension.deepdive",
        "key": "ctrl+l",
        "mac": "cmd+l",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "deepdive.newSession",
          "when": "view == deepdive.chatView",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "deepdive",
          "title": "DeepDive",
          "icon": "media/sidebar-icon.png"
        }
      ]
    },
    "views": {
      "deepdive": [
        {
          "type": "webview",
          "id": "deepdive.chatView",
          "name": "DeepDive",
          "icon": "media/sidebar-icon.png",
          "visibility": "visible"
        }
      ]
    }
  },
  "scripts": {
    "esbuild-base": "node scripts/esbuild.js",
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "tsc": "tsc -p ./",
    "tsc:check": "tsc -p ./ --noEmit",
    "lint": "eslint src --ext ts",
    "test": "vitest run",
    "package": "vsce package"
  },
  "dependencies": {
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "@types/vscode": "^1.70.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
